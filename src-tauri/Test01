version: 1
name: MR 审查-修复循环
target: /Users/zongfei/code/aicoda/loom-vscode
mode: auto
steps:
- id: mr
  kind: human
  instruction: 把要审查的 MR / PR 链接粘贴到产物框,引擎会传给后续步骤。
  expects: MR 链接
- id: checkout
  kind: claude
  prompt: 把 target 仓库切到 MR {{mr.artifact}} 对应的分支:优先 `gh pr checkout {{mr.artifact}}`,失败则从链接解析出分支名,用 git fetch + git checkout 切过去。完成后只输出当前分支名。
  skill: null
  verify: null
- id: review-fix
  kind: loop
  until: codex-clean
  max: 10
  body:
  - id: review
    kind: codex
    action: review-mr
    path: null
    base: dev
    prompt: null
  - id: fix
    kind: claude
    prompt: |-
      按 Codex 对 MR {{mr.artifact}} 的审查反馈,逐条修复后提交并 push 到该 MR 分支。若反馈为空或无需改动,则不做任何改动直接结束本步。

      Codex 反馈:
      {{review.findings}}
    skill: null
    verify: null
- id: done
  kind: human
  instruction: Codex 审查已通过(无遗留问题),确认 MR {{mr.artifact}} 可合并。
  expects: null
